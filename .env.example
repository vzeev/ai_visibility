POSTGRES_DB=ai_visibility
POSTGRES_USER=ai_visibility
POSTGRES_PASSWORD=ai_visibility_local
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://ai_visibility:ai_visibility_local@localhost:5432/ai_visibility
AI_VISIBILITY_TEST_DATABASE_URL=postgresql+psycopg://ai_visibility:ai_visibility_local@localhost:55432/ai_visibility_test
AI_VISIBILITY_ALLOW_DB_RESET=false
AI_VISIBILITY_DEMO_DATABASE_URL=postgresql+psycopg://ai_visibility:ai_visibility_local@localhost:5432/ai_visibility
AI_VISIBILITY_DEMO_FAKE_TOKEN=
AI_VISIBILITY_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

CONFIG_SERVICE_PORT=8001
VISIBILITY_SERVICE_PORT=8002
INSIGHTS_SERVICE_PORT=8003
WEB_PORT=5173
VITE_CONFIG_SERVICE_URL=http://localhost:8001
VITE_VISIBILITY_SERVICE_URL=http://localhost:8002
VITE_INSIGHTS_SERVICE_URL=http://localhost:8003

# Real provider execution reads the runtime key from OPENAI_API_KEY.
# Config UI credential records remain write-only metadata for this demo.
OPENAI_API_KEY=
ENABLE_OPENAI=false
